        </header>
    </div>

    <!-- ANA İÇERİK -->
    <main class="container">

        <!-- Mühendislik Bölümü -->
        <section class="section">
            <h2 class="section-title">⚡ Sistemler, Tasarım & Saha</h2>
            <div class="cards-grid">
                
                <article class="card">
                    <h3>Elektrik, Elektronik & Otomasyon</h3>
                    <p>Otomasyon sistemleri, donanım tasarımları, saha gözlemleri ve teknik incelemelerim.</p>
                    <span class="tag">Mühendislik</span>
                </article>

                <article class="card">
                    <h3>E-Plan, AutoCAD & Şematik Tasarım</h3>
