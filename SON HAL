<body>

    <!-- ÜST BÖLÜM VE FOTOĞRAF KAPSAYICISI -->
    <div class="hero-wrapper">
        <header class="hero">
            <div class="hero-overlay"></div>
            <div class="hero-content">
                <span class="badge">Çağrı'dan Dijital İzler</span>
                <h1>Akım, Kod ve Fikirler: Çağrı'nın Perspektifi!</h1>
                <p class="subtitle">Kabloların Ötesinde: Uygulamalar, Analizler ve Sayfalar.</p>
