                </article>

            </div>
        </section>

        <!-- Kitap İncelemeleri Bölümü -->
        <section class="section">
            <h2 class="section-title">📚 Zihin Kütüphanesi & Okumalar</h2>
            <div class="cards-grid">
                
                <!-- TIKLANABİLİR KART LINKI -->
                <a href="okuduklarim.html" class="card-link">
                    <article class="card">
                        <h3>Kitaplık & Fikir Deposu</h3>
                        <p>Disiplinlerarası okumalar, kütüphanemden notlar ve zihinsel süzgeçten geçen analizler.</p>
                        <div class="card-footer">
                            <span class="tag book-tag">Kitap</span>
                            <span class="read-more">Okuduklarımı Gör →</span>
                        </div>
                    </article>
                </a>

            </div>
        </section>

    </main>

    <!-- ALT BİLGİ (Footer) -->
    <footer>
        <p>© 2026 Çağrı - Tüm hakları saklıdır.</p>
    </footer>

</body>
